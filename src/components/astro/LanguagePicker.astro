---
import { getAllLanguageUrls, getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const languages = getAllLanguageUrls(Astro.url);
const currentLang = languages.find((l) => l.active);
---

<div class="relative inline-block text-left" id="language-picker">
    <!-- Trigger Button -->
    <button
        type="button"
        class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/5 text-xs text-gray-300 hover:text-white hover:border-white/20 transition-all font-medium group"
        id="lang-menu-button"
        aria-expanded="false"
        aria-haspopup="true"
    >
        <span class="uppercase">{currentLang?.code}</span>
        <svg
            class="w-3 h-3 text-gray-400 group-hover:text-gold transition-transform duration-300"
            id="lang-chevron"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
        </svg>
    </button>

    <!-- Dropdown Menu -->
    <div
        class="absolute right-0 mt-2 w-40 origin-top-right rounded-xl bg-[#0c111c]/90 backdrop-blur-xl border border-white/10 shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none transition-all duration-200 opacity-0 scale-95 pointer-events-none z-50"
        id="lang-dropdown"
        role="menu"
        aria-orientation="vertical"
        aria-labelledby="lang-menu-button"
        tabindex="-1"
    >
        <div class="p-1.5 flex flex-col gap-1" role="none">
            {
                languages.map((l) => (
                    <a
                        href={l.url}
                        class={`flex items-center justify-between px-3 py-2 rounded-lg text-sm transition-all duration-200 ${
                            l.active
                                ? "bg-gold/10 text-gold font-semibold"
                                : "text-gray-400 hover:text-white hover:bg-white/5"
                        }`}
                        role="menuitem"
                        tabindex="-1"
                    >
                        <span>{l.name}</span>
                        {l.active && (
                            <span class="w-1.5 h-1.5 rounded-full bg-gold shadow-[0_0_8px_rgba(192,139,90,0.8)]" />
                        )}
                    </a>
                ))
            }
        </div>
    </div>
</div>

<style>
    #language-picker.open #lang-dropdown {
        opacity: 1;
        scale: 1;
        pointer-events: auto;
    }

    #language-picker.open #lang-chevron {
        transform: rotate(180deg);
    }
</style>

<script>
    function setupLanguagePicker() {
        const picker = document.getElementById("language-picker");
        const btn = document.getElementById("lang-menu-button");

        if (!picker || !btn) return;

        // Toggle dropdown
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            picker.classList.toggle("open");
            const isExpanded = picker.classList.contains("open");
            btn.setAttribute("aria-expanded", isExpanded.toString());
        });

        // Close on outside click
        document.addEventListener("click", (e) => {
            if (!picker.contains(e.target as Node)) {
                picker.classList.remove("open");
                btn.setAttribute("aria-expanded", "false");
            }
        });

        // Close on Escape key
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                picker.classList.remove("open");
                btn.setAttribute("aria-expanded", "false");
            }
        });
    }

    // Run setup on initial load and after Astro swaps pages
    setupLanguagePicker();
    document.addEventListener("astro:after-swap", setupLanguagePicker);
</script>
